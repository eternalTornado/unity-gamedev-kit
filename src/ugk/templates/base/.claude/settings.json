{
  "$schema": "https://json.schemastore.org/claude-code-settings",
  "hooks": {
    "SessionStart": [
      { "command": ".claude/hooks/session-start.sh" },
      { "command": ".claude/hooks/detect-gaps.sh" }
    ],
    "PreCompact": [
      { "command": ".claude/hooks/pre-compact.sh" }
    ],
    "PostCompact": [
      { "command": ".claude/hooks/post-compact.sh" }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "command": ".claude/hooks/validate-commit.sh"
      },
      {
        "matcher": "Bash",
        "command": ".claude/hooks/validate-meta-files.sh"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(rm -rf:*)"
    ]
  }
}
